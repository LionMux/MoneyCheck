{
  "name": "moneycheck-windows-widget",
  "version": "1.2.0",
  "description": "MoneyCheck desktop widget for Windows",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/LionMux/MoneyCheck.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.moneycheck.widget",
    "productName": "MoneyCheck Widget",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "LionMux",
        "repo": "MoneyCheck"
      }
    ],
    "win": {
      "target": "nsis",
      "publisherName": "MoneyCheck"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    },
    "extraResources": [],
    "files": [
      "main.js",
      "preload.js",
      "widget.html",
      "package.json",
      "node_modules/**"
    ]
  }
}
