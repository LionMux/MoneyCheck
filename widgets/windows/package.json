{
  "name": "finwise-windows-widget",
  "version": "1.1.0",
  "description": "FinWise desktop widget for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.finwise.widget",
    "productName": "FinWise Widget",
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "../../client/public/icon-512.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    },
    "extraResources": [],
    "files": [
      "main.js",
      "preload.js",
      "widget.html",
      "package.json",
      "node_modules/**"
    ]
  }
}
