# ──────────────────────────────────────────────────────────
# FinWise — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string.
# If not set, the app runs in demo mode with in-memory storage (no auth).
DATABASE_URL=postgresql://finwise:your_password@localhost:5432/finwise

# ── Authentication ────────────────────────────────────────
# Random secret for signing JWT tokens. Must be at least 32 chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Email notifications (optional) ───────────────────────
# Used by the scheduler to send email reminders.
# Any SMTP-compatible service (Resend, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# SMTP_FROM=noreply@yourdomain.com

# ── Web Push (optional) ───────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com
